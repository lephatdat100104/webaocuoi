@model WebCUOI.Models.AoCuoi // Thay WebCUOI bằng tên dự án của bạn

@{
    ViewData["Title"] = "Chỉnh Sửa Áo Cưới";
}

<h1>Chỉnh Sửa Áo Cưới</h1>

<h4>Áo Cưới</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" /> @* Hidden field cho ID *@
            <input type="hidden" asp-for="NgayNhapKho" /> @* Giữ nguyên NgayNhapKho *@

            <div class="form-group">
                <label asp-for="TenAoCuoi" class="control-label"></label>
                <input asp-for="TenAoCuoi" class="form-control" />
                <span asp-validation-for="TenAoCuoi" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MoTa" class="control-label"></label>
                <textarea asp-for="MoTa" class="form-control"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GiaThue" class="control-label"></label>
                <input asp-for="GiaThue" class="form-control" />
                <span asp-validation-for="GiaThue" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="KichCo" class="control-label"></label>
                <input asp-for="KichCo" class="form-control" />
                <span asp-validation-for="KichCo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TinhTrang" class="control-label"></label>
                <input asp-for="TinhTrang" class="form-control" />
                <span asp-validation-for="TinhTrang" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HinhAnhURL" class="control-label"></label>
                <input asp-for="HinhAnhURL" class="form-control" />
                <span asp-validation-for="HinhAnhURL" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Lưu Thay Đổi" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Quay lại danh sách</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}