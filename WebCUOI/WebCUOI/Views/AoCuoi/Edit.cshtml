@model WebCUOI.Models.AoCuoi

@{
    ViewData["Title"] = "Chỉnh Sửa Áo Cưới";
}

<h2 class="text-center mb-4">Chỉnh Sửa Áo Cưới</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="ID" />
    <input type="hidden" asp-for="NgayNhapKho" />
    <input type="hidden" asp-for="HinhAnhURL" /> <!-- giữ lại ảnh cũ nếu không chọn ảnh mới -->

    <div class="form-group mb-3">
        <label asp-for="TenAoCuoi" class="form-label"></label>
        <input asp-for="TenAoCuoi" class="form-control" />
        <span asp-validation-for="TenAoCuoi" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MoTa" class="form-label"></label>
        <textarea asp-for="MoTa" class="form-control"></textarea>
        <span asp-validation-for="MoTa" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="GiaThue" class="form-label"></label>
        <input asp-for="GiaThue" class="form-control" />
        <span asp-validation-for="GiaThue" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="KichCo" class="form-label"></label>
        <input asp-for="KichCo" class="form-control" />
        <span asp-validation-for="KichCo" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="TinhTrang" class="form-label"></label>
        <input asp-for="TinhTrang" class="form-control" />
        <span asp-validation-for="TinhTrang" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Ảnh hiện tại</label><br />
        @if (!string.IsNullOrEmpty(Model.HinhAnhURL))
        {
            <img src="@Model.HinhAnhURL" alt="Ảnh áo cưới" style="max-height: 150px;" class="mb-2" />
        }
        else
        {
            <p class="text-muted">Chưa có ảnh</p>
        }
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Tải ảnh mới</label>
        <input type="file" name="ImageFile" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
