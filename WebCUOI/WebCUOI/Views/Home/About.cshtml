@{
    ViewData["Title"] = "Giới Thiệu Về Chúng Tôi"; // Sets the page title
}

<div class="container py-5">
    <h1 class="text-center mb-4">@ViewData["Title"]</h1>

    <div class="row featurette align-items-center mb-5">
        <div class="col-md-7 order-md-2">
            <h2 class="featurette-heading">Sứ Mệnh Của WebCUOI <span class="text-muted">Mang Hạnh Phúc Đến Mọi Nhà.</span></h2>
            <p class="lead">Tại WebCUOI, chúng tôi tin rằng mỗi câu chuyện tình yêu đều độc đáo và xứng đáng được tôn vinh bằng một đám cưới hoàn hảo. Sứ mệnh của chúng tôi là trở thành người bạn đồng hành đáng tin cậy, giúp các cặp đôi biến giấc mơ ngày cưới thành hiện thực một cách dễ dàng và đáng nhớ nhất.</p>
        </div>
        <div class="col-md-5 order-md-1">
            <img class="img-fluid rounded-circle shadow-lg" src="https://th.bing.com/th/id/OIP.2VkEdh5blcgMLchm0oyc_AHaE8?rs=1&pid=ImgDetMain" Sứ+Mệnh alt="Our Mission">
        </div>
    </div>

    <hr class="featurette-divider">

    <div class="row featurette align-items-center mb-5">
        <div class="col-md-7">
            <h2 class="featurette-heading">Đội Ngũ Chuyên Nghiệp <span class="text-muted">Tận Tâm Và Sáng Tạo.</span></h2>
            <p class="lead">Chúng tôi tự hào sở hữu đội ngũ chuyên gia giàu kinh nghiệm, từ những nhiếp ảnh gia tài năng, nhà thiết kế váy cưới sáng tạo, cho đến đội ngũ tổ chức sự kiện tỉ mỉ. Mỗi thành viên đều làm việc với niềm đam mê và sự tận tâm, cam kết mang đến những dịch vụ chất lượng cao nhất và sự hài lòng tuyệt đối cho khách hàng.</p>
        </div>
        <div class="col-md-5">
            <img class="img-fluid rounded-circle shadow-lg" src="https://www.anhieuwedding.com/wp-content/uploads/2024/01/be-trap-trong-le-cuoi-hoi-va-nhung-dieu-can-nam-ro-khi-be-trap-7.jpg" Đội+Ngũ alt="Our Team">
        </div>
    </div>

    <hr class="featurette-divider">

    <div class="row featurette align-items-center mb-5">
        <div class="col-md-7 order-md-2">
            <h2 class="featurette-heading">Giá Trị Cốt Lõi <span class="text-muted">Uy Tín, Chất Lượng, Sáng Tạo.</span></h2>
            <p class="lead">Chúng tôi xây dựng niềm tin dựa trên sự minh bạch, chuyên nghiệp và đạo đức kinh doanh. WebCUOI không ngừng đổi mới, cập nhật xu hướng và công nghệ để mang đến những trải nghiệm cưới hỏi độc đáo và đẳng cấp nhất. Sự hài lòng và hạnh phúc của khách hàng là thước đo thành công của chúng tôi.</p>
        </div>
        <div class="col-md-5 order-md-1">
            <img class="img-fluid rounded-circle shadow-lg" src="https://th.bing.com/th/id/OIP.fpQi_G_kNjbGybGd6O0EkgHaE8?w=228&h=180&c=7&r=0&o=5&dpr=1.4&pid=1.7" Giá+Trị alt="Core Values">
        </div>
    </div>

    <hr class="featurette-divider">

    <div class="text-center mt-5">
        <h2>Bạn Có Thể Tin Tưởng Vào Chúng Tôi!</h2>
        <p class="lead">Hãy để WebCUOI đồng hành cùng bạn trong hành trình tạo nên ngày trọng đại ý nghĩa nhất.</p>
        <a asp-controller="DichVuCuoiHoi" asp-action="Index" class="btn btn-primary btn-lg custom-primary-button">Khám Phá Dịch Vụ Cưới Hỏi</a>
        <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-secondary btn-lg ms-3">Liên Hệ Với Chúng Tôi</a>
    </div>
</div>