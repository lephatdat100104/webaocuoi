@{
    ViewBag.Title = "Thống kê đơn hàng";
}

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

<div class="container py-5">
    <h2 class="mb-4 text-center fw-bold">📊 Thống Kê Đơn Hàng</h2>

    @if (ViewBag.TongMatHang != null)
    {
        <!-- Thống kê thẻ -->
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-primary text-white h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Tổng Mặt Hàng</h5>
                        <p class="display-6 fw-bold">@ViewBag.TongMatHang</p>
                        <i class="bi bi-box-seam fs-1"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-success text-white h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Số Áo Cưới</h5>
                        <p class="display-6 fw-bold">@ViewBag.TongAoCuoi</p>
                        <i class="bi bi-person-fill fs-1"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-warning text-dark h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Số Dịch Vụ</h5>
                        <p class="display-6 fw-bold">@ViewBag.TongDichVu</p>
                        <i class="bi bi-gear-fill fs-1"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-danger text-white h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title">Tổng Tiền</h5>
                        <p class="display-6 fw-bold">@String.Format("{0:N0} VNĐ", ViewBag.TongTien)</p>
                        <i class="bi bi-currency-dollar fs-1"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Biểu đồ -->
        <hr class="my-5" />
        <h3 class="text-center fw-bold mb-4">📈 Biểu đồ Thống Kê Trực Quan</h3>

        <div class="row justify-content-center g-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header text-bg-primary text-white text-center fw-bold">
                        Tỷ lệ loại sản phẩm
                    </div>
                    <div class="card-body">
                        <canvas id="pieChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header text-bg-success text-white text-center fw-bold">
                        Tổng số mặt hàng theo loại
                    </div>
                    <div class="card-body">
                        <canvas id="barChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nút quay về -->
        <div class="text-center mt-5">
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-dark px-4 py-2">
                🏠 Về Trang Chủ
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <strong>Không có dữ liệu thống kê.</strong>
        </div>
        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Quay lại Trang chủ</a>
        </div>
    }
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const tongAoCuoi = @ViewBag.TongAoCuoi ?? 0;
    const tongDichVu = @ViewBag.TongDichVu ?? 0;
    const tongMatHang = @ViewBag.TongMatHang ?? 0;
    const tongTien = @ViewBag.TongTien ?? 0;

    // Biểu đồ tròn
    const ctxPie = document.getElementById('pieChart').getContext('2d');
    new Chart(ctxPie, {
        type: 'pie',
        data: {
            labels: ['Áo Cưới', 'Dịch Vụ Cưới Hỏi'],
            datasets: [{
                data: [tongAoCuoi, tongDichVu],
                backgroundColor: ['#0d6efd', '#ffc107'],
                borderColor: '#fff',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });

    // Biểu đồ cột
    const ctxBar = document.getElementById('barChart').getContext('2d');
    new Chart(ctxBar, {
        type: 'bar',
        data: {
            labels: ['Áo Cưới', 'Dịch Vụ'],
            datasets: [{
                label: 'Số lượng',
                data: [tongAoCuoi, tongDichVu],
                backgroundColor: ['#20c997', '#fd7e14']
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });
</script>
