@{
    ViewData["Title"] = "Kết Quả Thanh Toán VNPAY";
}

<h2 class="mt-4">Kết Quả Thanh Toán</h2>

<div class="mt-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            <h4 class="alert-heading">Thanh toán thành công!</h4>
            <p>@TempData["SuccessMessage"]</p>
            <hr>
            <p class="mb-0">Cảm ơn bạn đã mua sắm tại WebCUOI. Bạn có thể kiểm tra lịch sử đơn hàng của mình.</p>
        </div>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Thanh toán thất bại!</h4>
            <p>@TempData["ErrorMessage"]</p>
            <hr>
            <p class="mb-0">Vui lòng kiểm tra lại thông tin hoặc liên hệ hỗ trợ nếu cần.</p>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">Đang xử lý...</h4>
            <p>Chúng tôi đang xử lý kết quả thanh toán của bạn. Vui lòng không đóng trang này.</p>
        </div>
    }
</div>

<div class="mt-4 text-center">
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
        <i class="bi bi-house-door-fill"></i> Về trang chủ
    </a>
    <a asp-controller="GioHang" asp-action="LichSuMuaHang" class="btn btn-info">
        <i class="bi bi-clock-history"></i> Xem lịch sử mua hàng
    </a>
</div>