@model IEnumerable<WebCUOI.Models.DichVuCuoiHoi>

@{
    ViewData["Title"] = "Dịch Vụ Cưới Hỏi";
}

<h2 class="mb-3 text-center text-primary fw-bold" style="font-family: 'Playfair Display', serif;">
    💒 Dịch Vụ Cưới Hỏi
</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-plus me-2"></i> Thêm Dịch Vụ
        </a>
    }

    <div class="input-group w-25">
        <span class="input-group-text bg-white"><i class="fas fa-search"></i></span>
        <input type="search" class="form-control" placeholder="Tìm kiếm..." id="searchInput" />
    </div>
</div>

<div class="row g-4" id="albumDichVu">
    @foreach (var item in Model)
    {
        

        <div class="col-md-4 col-lg-4 col-sm-6 dichVuCard">

            <div class="card shadow-sm border-0 h-100">
                <div class="position-relative">
                    <img src="@(!string.IsNullOrEmpty(item.HinhAnhURL) ? item.HinhAnhURL : Url.Content("~/images/no-image.png"))"
                         class="card-img-top"
                         alt="@item.TenDichVu"
                         style="height:260px; object-fit:cover; border-top-left-radius:10px; border-top-right-radius:10px;" />
                </div>

                <div class="card-body text-center">
                    <h5 class="card-title fw-bold">@item.TenDichVu</h5>
                    <p class="card-text text-danger fw-semibold mb-1">
                        @item.GiaDichVu.ToString("N0") đ
                    </p>
                    <p class="text-muted small mb-3">
                        Thời lượng: @item.ThoiLuong
                    </p>

                    <div class="d-flex justify-content-center flex-wrap gap-1">
                        <!-- Nút gộp: chỉ 1 nút Xem chi tiết -->
                        <a asp-action="Details"
                           asp-route-id="@item.ID"
                           class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-eye me-1"></i> Thuê ngay
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.ID"
                               class="btn btn-outline-warning btn-sm">
                                <i class="fas fa-edit me-1"></i> Sửa
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.ID"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Bạn có chắc muốn xóa dịch vụ này không?');">
                                <i class="fas fa-trash-alt me-1"></i> Xóa
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

    <script>
        // Tìm kiếm theo tên dịch vụ trong album
        const searchInput = document.getElementById('searchInput');
        const cards = document.querySelectorAll('.dichVuCard');

        searchInput.addEventListener('keyup', function () {
            const filter = this.value.toLowerCase();
            cards.forEach(card => {
                const name = card.querySelector('.card-title').textContent.toLowerCase();
                card.style.display = name.includes(filter) ? '' : 'none';
            });
        });
    </script>
}
