@model WebCUOI.Models.DichVuCuoiHoi

@{
    ViewData["Title"] = "Chỉnh sửa dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Chỉnh sửa dịch vụ cưới hỏi</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" />

            <div class="form-group">
                <label asp-for="TenDichVu" class="control-label"></label>
                <input asp-for="TenDichVu" class="form-control" />
                <span asp-validation-for="TenDichVu" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MoTa" class="control-label"></label>
                <textarea asp-for="MoTa" class="form-control"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GiaDichVu" class="control-label"></label>
                <input asp-for="GiaDichVu" class="form-control" />
                <span asp-validation-for="GiaDichVu" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ThoiLuong" class="control-label"></label>
                <input asp-for="ThoiLuong" class="form-control" />
                <span asp-validation-for="ThoiLuong" class="text-danger"></span>
            </div>

            <div class="form-group form-check">
                <input class="form-check-input" asp-for="KhacDung" />
                <label class="form-check-label" asp-for="KhacDung"></label>
            </div>

            <div class="form-group">
                <label>Ảnh hiện tại</label><br />
                @if (!string.IsNullOrEmpty(Model.HinhAnhURL))
                {
                        <img src="@Model.HinhAnhURL" alt="Ảnh dịch vụ" width="200" class="img-thumbnail mb-2" />
                }
            </div>

            <div class="form-group">
                <label>Chọn ảnh mới (nếu muốn thay)</label>
                <input type="file" name="ImageFile" class="form-control-file" />
            </div>

            <div class="form-group">
                <input type="submit" value="Lưu thay đổi" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ml-2">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
