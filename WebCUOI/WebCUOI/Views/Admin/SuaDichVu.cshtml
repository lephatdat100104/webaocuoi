@model WebCUOI.Models.DichVuCuoiHoi

@{
    ViewData["Title"] = "Sửa Dịch Vụ";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="SuaDichVu" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ID" />

    <div class="form-group mb-3">
        <label asp-for="TenDichVu"></label>
        <input asp-for="TenDichVu" class="form-control" />
        <span asp-validation-for="TenDichVu" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MoTa"></label>
        <textarea asp-for="MoTa" class="form-control"></textarea>
        <span asp-validation-for="MoTa" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="GiaDichVu"></label>
        <input asp-for="GiaDichVu" class="form-control" />
        <span asp-validation-for="GiaDichVu" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ThoiLuong"></label>
        <input asp-for="ThoiLuong" class="form-control" />
        <span asp-validation-for="ThoiLuong" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="KhacDung" class="form-check-input" />
        <label asp-for="KhacDung" class="form-check-label"></label>
    </div>

    <div class="form-group mb-3">
        <label>Hình hiện tại</label><br />
        @if (!string.IsNullOrEmpty(Model.HinhAnhURL))
        {
            <img src="@Model.HinhAnhURL" alt="Hình ảnh" width="150" />
        }
    </div>

    <div class="form-group mb-3">
        <label for="ImageFile">Cập nhật hình ảnh mới</label>
        <input type="file" name="ImageFile" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="QuanLyDichVu" class="btn btn-secondary">Hủy</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
