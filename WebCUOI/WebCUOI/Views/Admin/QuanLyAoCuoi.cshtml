@model IEnumerable<WebCUOI.Models.AoCuoi>

@{
    ViewData["Title"] = "Quản Lý Áo Cưới";
}

<h1 class="text-center mb-4">@ViewData["Title"]</h1>

<p>
    <a asp-action="TaoAoCuoi" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Thêm Áo Cưới Mới</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="bg-primary text-white">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.TenAoCuoi)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.GiaThue)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.KichCo)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.TinhTrang)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.NgayNhapKho)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.HinhAnhURL)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.TenAoCuoi)
                    </td>
                    <td>
                        @item.GiaThue.ToString("N0") VNĐ
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.KichCo)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.TinhTrang)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.NgayNhapKho)
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.HinhAnhURL))
                        {
                            <img src="@item.HinhAnhURL" alt="@item.TenAoCuoi" width="80" height="80" style="object-fit: cover; border-radius: 5px;" />
                        }
                        else
                        {
                            <span>Không ảnh</span>
                        }
                    </td>
                    <td>
                        <a asp-action="SuaAoCuoi" asp-route-id="@item.ID" class="btn btn-sm btn-warning mb-1"><i class="bi bi-pencil-fill"></i> Sửa</a> |
                        <a asp-action="XoaAoCuoi" asp-route-id="@item.ID" class="btn btn-sm btn-danger mb-1"><i class="bi bi-trash-fill"></i> Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>