@model IEnumerable<WebCUOI.Models.DonHang>

@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
}

<h2 class="text-center mb-4" style="color: #007bff;">
    <i class="fas fa-clipboard-list"></i> Quản Lý Đơn Hàng
</h2>

<table class="table table-bordered text-center table-striped">
    <thead class="table-primary">
        <tr>
            <th>Mã ĐH</th>
            <th>Khách Hàng</th>
            <th>Ngày Đặt</th>
            <th>Tổng Tiền</th>
            <th>Trạng Thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderByDescending(d => d.NgayDat))
        {
            <tr>
                <td>@item.ID</td>
                <td>@item.KhachHang?.Email</td>
                <td>@item.NgayDat.ToString("M/d/yyyy hh:mm:ss tt")</td>
                <td>@item.TongTien.ToString("N0") VNĐ</td>
                <td>
                    @item.TrangThai ?? "Đang chờ xử lý"
                </td>
                <td>
                    <a asp-action="ChiTietDonHang" asp-route-id="@item.ID" class="btn btn-info btn-sm text-white">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>
