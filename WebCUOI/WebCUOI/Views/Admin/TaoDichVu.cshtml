@model WebCUOI.Models.DichVuCuoiHoi

@{
    ViewData["Title"] = "Tạo Dịch Vụ Cưới Hỏi";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<form asp-action="TaoDichVu" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        <label asp-for="TenDichVu" class="form-label"></label>
        <input asp-for="TenDichVu" class="form-control" />
        <span asp-validation-for="TenDichVu" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MoTa" class="form-label"></label>
        <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
        <span asp-validation-for="MoTa" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="GiaDichVu" class="form-label"></label>
        <input asp-for="GiaDichVu" class="form-control" />
        <span asp-validation-for="GiaDichVu" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ThoiLuong" class="form-label"></label>
        <input asp-for="ThoiLuong" class="form-control" />
        <span asp-validation-for="ThoiLuong" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="KhacDung" class="form-check-input" />
        <label asp-for="KhacDung" class="form-check-label"></label>
    </div>

    <div class="form-group mb-3">
        <label for="ImageFile" class="form-label">Hình Ảnh</label>
        <input type="file" name="ImageFile" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Tạo mới</button>
    <a asp-action="QuanLyDichVu" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
